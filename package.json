{
  "name": "frankgrant",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler pages deploy dist --project-name frankgrant",
    "worker:dev": "wrangler dev workers/api.js",
    "worker:deploy": "wrangler deploy workers/api.js",
    "db:init": "wrangler d1 execute frankgrant-db --file=schema.sql",
    "db:init:remote": "wrangler d1 execute frankgrant-db --remote --file=schema.sql"
  },
  "dependencies": {
    "@clerk/clerk-react": "^5.0.0",
    "mammoth": "^1.12.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "vite": "^5.4.0",
    "wrangler": "^3.80.0"
  }
}
